<Window x:Class="AplicacionClientesyReparaciones.Views.DetalleClienteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalle de cliente" Height="560" Width="640" Background="#F3F6FB">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#2563EB" />
        </Style>
    </Window.Resources>
    <Border Margin="20" Background="White" CornerRadius="12" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Detalle de cliente"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#1F2937"
                   Margin="0,0,0,16" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="ID:" Margin="0,0,10,5" />
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Id}" IsReadOnly="True" Margin="0,0,0,5" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Nombre:" Margin="0,0,10,5" />
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="NombreTextBox" Text="{Binding Nombre}" Margin="0,0,0,5" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Apellidos:" Margin="0,0,10,5" />
            <TextBox Grid.Row="2" Grid.Column="1" x:Name="ApellidosTextBox" Text="{Binding Apellidos}" Margin="0,0,0,5" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="DNI:" Margin="0,0,10,5" />
            <TextBox Grid.Row="3" Grid.Column="1" x:Name="DniTextBox" Text="{Binding Dni}" Margin="0,0,0,5" />

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Movil 1:" Margin="0,0,10,5" />
            <TextBox Grid.Row="4" Grid.Column="1" x:Name="Telefono1TextBox" Text="{Binding Telefono1}" Margin="0,0,0,5" />

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Movil 2:" Margin="0,0,10,5" />
            <TextBox Grid.Row="5" Grid.Column="1" x:Name="Telefono2TextBox" Text="{Binding Telefono2}" Margin="0,0,0,5" />

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Email:" Margin="0,0,10,5" />
            <TextBox Grid.Row="6" Grid.Column="1" x:Name="EmailTextBox" Text="{Binding Email}" Margin="0,0,0,5" />

            <TextBlock Grid.Row="7" Grid.Column="0" Text="Dirección:" Margin="0,0,10,5" />
            <TextBox Grid.Row="7" Grid.Column="1" x:Name="DireccionTextBox" Text="{Binding Direccion}" Margin="0,0,0,5" />

            <TextBlock Grid.Row="8" Grid.Column="0" Text="Población:" Margin="0,0,10,5" />
            <TextBox Grid.Row="8" Grid.Column="1" x:Name="PoblacionTextBox" Text="{Binding Poblacion}" Margin="0,0,0,5" />

            <TextBlock Grid.Row="9" Grid.Column="0" Text="Provincia:" Margin="0,0,10,5" />
            <TextBox Grid.Row="9" Grid.Column="1" x:Name="ProvinciaTextBox" Text="{Binding Provincia}" Margin="0,0,0,5" />

            <TextBlock Grid.Row="10" Grid.Column="0" Text="Observaciones:" Margin="0,0,10,5" VerticalAlignment="Top" />
            <TextBox Grid.Row="10" Grid.Column="1" x:Name="ObservacionesTextBox" Text="{Binding Observaciones}" Margin="0,0,0,5" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="100" />
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Guardar" Width="110" Margin="0,0,12,0" Click="Guardar_Click" />
            <Button Content="Cerrar" Width="110" Background="#64748B" BorderBrush="#64748B" IsCancel="True" />
        </StackPanel>
    </Grid>
    </Border>
</Window>
