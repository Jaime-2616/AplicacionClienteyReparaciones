<UserControl x:Class="AplicacionClientesyReparaciones.Views.AgregarCliente"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<TextBlock Grid.Row="0"
			   Text="Agregar cliente"
			   FontSize="18"
			   FontWeight="Bold"
			   Margin="0,0,0,10" />

		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>


			<TextBlock Grid.Row="0" Grid.Column="0" Text="Nombre:" Margin="0,0,10,5" VerticalAlignment="Center" />
			<TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,5" x:Name="NombreTextBox" />

			<TextBlock Grid.Row="1" Grid.Column="0" Text="DNI:" Margin="0,0,10,5" VerticalAlignment="Center" />
			<TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,5" x:Name="DniTextBox" />

			<TextBlock Grid.Row="2" Grid.Column="0" Text="Apellidos:" Margin="0,0,10,5" VerticalAlignment="Center" />
			<TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,5" x:Name="ApellidosTextBox" />

			<TextBlock Grid.Row="3" Grid.Column="0" Text="Teléfono 1:" Margin="0,0,10,5" VerticalAlignment="Center" />
			<TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,5" x:Name="Telefono1TextBox" />

			<TextBlock Grid.Row="4" Grid.Column="0" Text="Email:" Margin="0,0,10,5" VerticalAlignment="Center" />
			<TextBox Grid.Row="4" Grid.Column="1" Margin="0,0,0,5" x:Name="EmailTextBox" />

			<TextBlock Grid.Row="5" Grid.Column="0" Text="Dirección:" Margin="0,0,10,5" VerticalAlignment="Center" />
			<TextBox Grid.Row="5" Grid.Column="1" Margin="0,0,0,5" x:Name="DireccionTextBox" />

			<TextBlock Grid.Row="6" Grid.Column="0" Text="Población:" Margin="0,0,10,5" VerticalAlignment="Center" />
			<TextBox Grid.Row="6" Grid.Column="1" Margin="0,0,0,5" x:Name="PoblacionTextBox" />

			<TextBlock Grid.Row="7" Grid.Column="0" Text="Provincia:" Margin="0,0,10,5" VerticalAlignment="Center" />
			<TextBox Grid.Row="7" Grid.Column="1" Margin="0,0,0,5" x:Name="ProvinciaTextBox" />

			<TextBlock Grid.Row="8" Grid.Column="0" Text="Teléfono 2:" Margin="0,0,10,5" VerticalAlignment="Center" />
			<TextBox Grid.Row="8" Grid.Column="1" Margin="0,0,0,5" x:Name="Telefono2TextBox" />

			<TextBlock Grid.Row="9" Grid.Column="0" Text="Observaciones:" Margin="0,0,10,5" VerticalAlignment="Top" />
			<TextBox Grid.Row="9" Grid.Column="1" Margin="0,0,0,5" x:Name="ObservacionesTextBox"
					 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="100" />
		
		
		</Grid>

		<StackPanel Grid.Row="2"
				Orientation="Horizontal"
				HorizontalAlignment="Right"
				Margin="0,10,0,0">
			<Button Content="Cancelar" Width="90" Margin="0,0,10,0" Click="Salir" />
			<Button Content="Guardar" Width="90" Click="Guardar_Click" />
		</StackPanel>
	</Grid>
</UserControl>
