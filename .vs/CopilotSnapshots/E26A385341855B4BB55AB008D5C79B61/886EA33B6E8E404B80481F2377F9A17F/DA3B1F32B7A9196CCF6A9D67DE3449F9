<Window x:Class="AplicacionClientesyReparaciones.Views.DetalleReparacionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalle de reparación" Height="660" Width="760" MinHeight="620" MinWidth="720" Background="#F3F6FB">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="6,0" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#2563EB" />
        </Style>
    </Window.Resources>
    <Border Margin="20" Background="White" CornerRadius="12" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Detalle de reparación"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#1F2937"
                   Margin="0,0,0,16" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Cliente:" Margin="0,0,10,5" />
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding NombreCliente}" IsReadOnly="True" Margin="0,0,0,5" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Movil:" Margin="0,0,10,5" />
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Telefono1}" IsReadOnly="True" Margin="0,0,0,5" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Fecha entrega:" Margin="0,0,10,5" />
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding FechaDeEntrega, StringFormat=dd/MM/yyyy}" IsReadOnly="True" Margin="0,0,0,5" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Material:" Margin="0,0,10,5" />
            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding MaterialEntregado}" IsReadOnly="True" Margin="0,0,0,5" />

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Descripción:" Margin="0,0,10,5" VerticalAlignment="Top" />
                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Descripcion}" IsReadOnly="True" Margin="0,0,0,5" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"  Height="120" VerticalContentAlignment="Top" />

			<TextBlock Grid.Row="5" Grid.Column="0" Text="Estado:" Margin="0,0,10,5" VerticalAlignment="Center" />
            <ComboBox Grid.Row="5" Grid.Column="1" Margin="0,0,0,5" x:Name="EstadoComboBox"
					  SelectedValuePath="Content"
					  SelectedValue="{Binding Estado, Mode=TwoWay}">
                <ComboBoxItem Content="Pendiente" />
                <ComboBoxItem Content="En proceso" />
                <ComboBoxItem Content="Finalizada" />
            </ComboBox>

			<TextBlock Grid.Row="6" Grid.Column="0" Text="Precio:" Margin="0,0,10,5" />
			<TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Precio}" IsReadOnly="True" Margin="0,0,0,5" />
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Imprimir" Width="110" Margin="0,0,12,0" Click="Imprimir_Click" />
            <Button Content="Guardar" Width="120" Margin="0,0,12,0" Click="GuardarEstado_Click" />
            <Button Content="Cerrar" Width="110" Background="#64748B" BorderBrush="#64748B" IsCancel="True" />
        </StackPanel>
    </Grid>
    </Border>
</Window>
