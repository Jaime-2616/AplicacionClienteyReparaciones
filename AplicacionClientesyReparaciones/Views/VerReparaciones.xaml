<UserControl x:Class="AplicacionClientesyReparaciones.Views.VerReparaciones"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Listado de reparaciones" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
            <Button Grid.Column="1"
				Content="Crear Reparacion"
				Width="120"
				Height="30"
				HorizontalAlignment="Right"
                Click=" NuevaReparacion_Click"/>
        </Grid>
		<DataGrid Grid.Row="1"
			  x:Name="ReparacionesDataGrid"
			  AutoGenerateColumns="False"
			  IsReadOnly="True">
			<DataGrid.Columns>
				<DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
				<DataGridTextColumn Header="Cliente" Binding="{Binding NombreCliente}" Width="*" />
				<DataGridTextColumn Header="Teléfono" Binding="{Binding Telefono1}" Width="*" />
				<DataGridTextColumn Header="Fecha entrega" Binding="{Binding FechaDeEntrega}" Width="*" />
				<DataGridTextColumn Header="Material" Binding="{Binding MaterialEntregado}" Width="*" />
				<DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="2*" />
			</DataGrid.Columns>
		</DataGrid>
    </Grid>
</UserControl>
