<Window x:Class="AplicacionClientesyReparaciones.Views.DetalleClienteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalle de cliente" Height="450" Width="500">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Detalle de cliente"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,10" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="ID:" Margin="0,0,10,5" />
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Id}" IsReadOnly="True" Margin="0,0,0,5" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Nombre:" Margin="0,0,10,5" />
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Nombre}" IsReadOnly="True" Margin="0,0,0,5" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Apellidos:" Margin="0,0,10,5" />
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Apellidos}" IsReadOnly="True" Margin="0,0,0,5" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="DNI:" Margin="0,0,10,5" />
            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Dni}" IsReadOnly="True" Margin="0,0,0,5" />

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Teléfono 1:" Margin="0,0,10,5" />
            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Telefono1}" IsReadOnly="True" Margin="0,0,0,5" />

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Teléfono 2:" Margin="0,0,10,5" />
            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Telefono2}" IsReadOnly="True" Margin="0,0,0,5" />

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Email:" Margin="0,0,10,5" />
            <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Email}" IsReadOnly="True" Margin="0,0,0,5" />

            <TextBlock Grid.Row="7" Grid.Column="0" Text="Dirección:" Margin="0,0,10,5" />
            <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding Direccion}" IsReadOnly="True" Margin="0,0,0,5" />

            <TextBlock Grid.Row="8" Grid.Column="0" Text="Población:" Margin="0,0,10,5" />
            <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding Poblacion}" IsReadOnly="True" Margin="0,0,0,5" />

            <TextBlock Grid.Row="9" Grid.Column="0" Text="Provincia:" Margin="0,0,10,5" />
            <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding Provincia}" IsReadOnly="True" Margin="0,0,0,5" />

            <TextBlock Grid.Row="10" Grid.Column="0" Text="Observaciones:" Margin="0,0,10,5" VerticalAlignment="Top" />
            <TextBox Grid.Row="10" Grid.Column="1" Text="{Binding Observaciones}" IsReadOnly="True" Margin="0,0,0,5" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="100" />
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cerrar" Width="90" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
